{
  "id": "memory-lightrag",
  "kind": "memory",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "baseUrl": { "type": "string" },
      "apiKey": { "type": "string" },
      "timeoutMs": { "type": "number", "minimum": 1000, "maximum": 30000 },
      "retryCount": { "type": "number", "minimum": 0, "maximum": 3 },
      "recallTopK": { "type": "number", "minimum": 1, "maximum": 20 },
      "minScore": { "type": "number", "minimum": 0, "maximum": 1 },
      "recallBudgetChars": { "type": "number", "minimum": 200, "maximum": 8000 },
      "includeCitations": { "type": "boolean" },
      "enableSafetyFilter": { "type": "boolean" }
    },
    "required": ["baseUrl"]
  }
}
